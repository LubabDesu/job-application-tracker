{
  "manifest_version": 3,
  "name": "Job Tracker",
  "version": "0.1.0",
  "description": "Auto-log job applications to Notion as you apply on Workday and Greenhouse.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://*.greenhouse.io/*", "http://localhost/*", "https://*.myworkdayjobs.com/*", "https://*.ashbyhq.com/*"],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.greenhouse.io/*"],
      "js": ["src/content/greenhouse.ts"]
    },
    {
      "matches": ["https://*.myworkdayjobs.com/*"],
      "js": ["src/content/workday.ts"]
    },
    {
      "matches": ["https://*.ashbyhq.com/*"],
      "js": ["src/content/ashby.ts"]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Job Tracker",
    "default_icon": {
      "16": "src/icons/icon.svg",
      "48": "src/icons/icon.svg",
      "128": "src/icons/icon.svg"
    }
  },
  "icons": {
    "16": "src/icons/icon.svg",
    "48": "src/icons/icon.svg",
    "128": "src/icons/icon.svg"
  }
}
